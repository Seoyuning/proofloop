# =====================================================================
# AI Provider 선택
# =====================================================================
# 전역 기본값. 비워두면 채팅/진단 둘 다 비활성 (API 호출 없음, 휴리스틱만 동작)
# 가능 값: skt | lg-exaone | upstage-solar | kt-midm
AI_PROVIDER=

# (선택) 사용 사례별 오버라이드. 채팅/진단을 다른 모델로 분리하고 싶을 때 사용
# AI_PROVIDER_CHAT=skt
# AI_PROVIDER_DIAGNOSIS=lg-exaone

# =====================================================================
# SKT A.X K1 (OpenAI 호환 API). 발급 정보는 본선 시작 전 SKT에서 안내
# =====================================================================
SKT_API_KEY=
SKT_BASE_URL=https://api.platform.a.x/v1
SKT_MODEL=ax-k1

# =====================================================================
# LG K-EXAONE (FriendliAI Dedicated Endpoint, OpenAI 호환) — 대회 공식 가이드
# API Key는 flp_ 로 시작. FRIENDLI_MODEL은 K-EXAONE가 배포된 "Endpoint ID"
# (FriendliAI 대시보드의 Dedicated Endpoints에서 확인)
# =====================================================================
FRIENDLI_API_KEY=
FRIENDLI_BASE_URL=https://api.friendli.ai/dedicated/v1
FRIENDLI_MODEL=

# =====================================================================
# Upstage Solar Pro 3 / Document Parse / Information Extract
# 발급: https://console.upstage.ai/
# =====================================================================
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1/solar
UPSTAGE_MODEL=solar-pro

# =====================================================================
# KT Mi:dm 2.0 Base (오픈웨이트, FriendliAI 호스팅 또는 자체 호스팅)
# HuggingFace: K-intelligence/Midm-2.0-Base-Instruct (MIT 라이선스)
# =====================================================================
KT_API_KEY=
KT_BASE_URL=https://api.friendli.ai/serverless/v1
KT_MODEL=K-intelligence/Midm-2.0-Base-Instruct

# =====================================================================
# NC VARCO (이미지/3D/사운드/음성 생성. LLM 아님 - 별도 API 호출용)
# 발급: https://api.varco.ai/ko
# =====================================================================
VARCO_API_KEY=
VARCO_WORKSPACE_ID=
