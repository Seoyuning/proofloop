# =====================================================================
# AI Provider 선택
# =====================================================================
# 전역 기본값. 비워두면 채팅/진단 둘 다 비활성 (API 호출 없음, 휴리스틱만 동작)
# 가능 값: skt | lg-exaone | upstage-solar | kt-midm
AI_PROVIDER=

# (선택) 사용 사례별 오버라이드. 채팅/진단을 다른 모델로 분리하고 싶을 때 사용
# AI_PROVIDER_CHAT=skt
# AI_PROVIDER_DIAGNOSIS=lg-exaone

# =====================================================================
# SKT A.X K1 (OpenAI 호환 API). 발급 정보는 본선 시작 전 SKT에서 안내
# =====================================================================
SKT_API_KEY=
SKT_BASE_URL=https://api.platform.a.x/v1
SKT_MODEL=ax-k1

# =====================================================================
# LG K-EXAONE (FriendliAI Dedicated Endpoint, OpenAI 호환) — 대회 공식 가이드
# API Key는 flp_ 로 시작. FRIENDLI_MODEL은 K-EXAONE가 배포된 "Endpoint ID"
# (FriendliAI 대시보드의 Dedicated Endpoints에서 확인)
# =====================================================================
FRIENDLI_API_KEY=
FRIENDLI_BASE_URL=https://api.friendli.ai/dedicated/v1
FRIENDLI_MODEL=

# =====================================================================
# Upstage Solar Pro 3 / Document Parse / Information Extract
# 발급: https://console.upstage.ai/
# =====================================================================
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1/solar
UPSTAGE_MODEL=solar-pro
# 임베딩 (RAG: 업로드 학습자료 검색용). UPSTAGE_API_KEY를 공유한다. 보통 기본값으로 충분.
UPSTAGE_EMBED_URL=https://api.upstage.ai/v1/embeddings
UPSTAGE_EMBED_MODEL_QUERY=embedding-query
UPSTAGE_EMBED_MODEL_PASSAGE=embedding-passage

# =====================================================================
# KT Mi:dm 2.0 (FriendliAI Dedicated Endpoint — EXAONE와 동일 방식)
# 키는 flp_ 로 시작, KT_MODEL은 배포된 "Endpoint ID"(dep... 형식).
# base는 반드시 /dedicated/v1 로 끝나야 함 (끝의 /v1 빠지면 404).
# =====================================================================
KT_API_KEY=
KT_BASE_URL=https://api.friendli.ai/dedicated/v1
KT_MODEL=

# =====================================================================
# NC VARCO (이미지/3D/사운드/음성 생성. LLM 아님 - 별도 API 호출용)
# 발급: https://api.varco.ai/ko
# =====================================================================
VARCO_API_KEY=
VARCO_WORKSPACE_ID=

# =====================================================================
# Supabase (앱 런타임용 — 보통 Vercel/배포 환경에 설정)
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키: 문제은행 적재 스크립트(scripts/ingest-problem-bank.mjs) "로컬 실행" 전용.
# 절대 클라이언트/배포 번들에 넣지 말 것. (Supabase 대시보드 → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=
